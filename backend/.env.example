# =====================================================================
# ARCHIVO DE EJEMPLO — Copiar como .env y completar con valores reales
# NUNCA subir el archivo .env al repositorio
# =====================================================================

# Configuración del servidor
HOST=0.0.0.0
PORT=8000
DEBUG=False          # Cambiar a True solo en desarrollo local

# Base de datos
DATABASE_URL=sqlite:///./data/hospital_ia.db

# ChromaDB
CHROMA_PATH=./data/chromadb
CHROMA_COLLECTION=hospital_docs

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_FALLBACK_MODEL=phi3:mini

# JWT Autenticación
# IMPORTANTE: Generar una clave aleatoria segura para producción.
# Ejemplo: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-USE-A-RANDOM-32-CHAR-STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — Orígenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Usuario administrador inicial (usado por create_db.py)
ADMIN_EMAIL=admin@corevital.com
ADMIN_PASSWORD=

# Configuración RAG
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# Límites de archivos
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx

# Logs
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
